{
  "manifest_version": 3,
  "name": "Vintamie Assistant",
  "version": "2.2.72",
  "description": "F\u00fclle deine Vinted und Kleinanzeigen Inserate automatisch aus dem Vintamie-Dashboard aus.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:5173/*",
    "https://vintamie.henrikheil.net/*",
    "https://*.vinted.de/*",
    "https://*.kleinanzeigen.de/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.vinted.de/items/new*",
        "https://*.vinted.fr/items/new*",
        "https://*.kleinanzeigen.de/p-anzeige-aufgeben.html*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_end"
    },
    {
      "matches": [
        "http://localhost:5173/*",
        "https://vintamie.henrikheil.net/*"
      ],
      "js": [
        "content_sync.js"
      ],
      "run_at": "document_end"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "camera.html",
        "camera.js",
        "camera.css"
      ],
      "matches": [
        "https://*.vinted.de/*",
        "https://*.vinted.fr/*",
        "https://*.kleinanzeigen.de/*"
      ]
    }
  ]
}
