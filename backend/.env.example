# Vintamie Backend Environment Configuration
# Copy this file to .env in the same directory and fill in your values.

# Google Gemini API Key (get it from Google AI Studio)
GEMINI_API_KEY=your_gemini_api_key_here

# Secret key for JWT auth token signing (change this to a random secure string)
SECRET_KEY=vintamie_super_secret_signing_key_change_me_in_production

# Token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Google OAuth Client ID for Social Login (obtain from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here
